#!/usr/bin/env bash
# dev-workflow 硬后盾:git 原生 pre-push 钩子,在 git 内部同步执行,
# 不受 Claude bypass 模式竞态影响。
# 策略:功能分支放行;推送到 main/master 仍需人工批准(HUMAN_PUSH=1 / approve-push)。
# 由 wf-protect 安装到某个仓库的 .git/hooks/pre-push。

protected='refs/heads/(main|master)$'
touches_protected=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "$remote_ref" ] && continue
  echo "$remote_ref" | grep -qE "$protected" && touches_protected=1
done

if [ "$touches_protected" = "1" ] && [ "${HUMAN_PUSH:-0}" != "1" ]; then
  echo "" >&2
  echo "⛔ push 到 main/master 被 dev-workflow 拦截:此次推送未经人工批准。" >&2
  echo "   审核 diff 后,自行推送:  approve-push   (等价于 HUMAN_PUSH=1 git push)" >&2
  echo "" >&2
  exit 1
fi

# 已放行:链式调用仓库原有的 pre-push(如 husky),避免其它钩子失效
for h in ".husky/pre-push" ".git/hooks/pre-push.local"; do
  if [ -x "$h" ]; then exec "$h" "$@"; fi
done

exit 0

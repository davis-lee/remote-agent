#!/bin/bash
# 检测一个或多个域名/主机能否从容器内访问,并区分失败原因。
#   用法: fw-check api.stripe.com github.com 203.0.113.10
set -uo pipefail
[ "$#" -eq 0 ] && { echo "用法: fw-check <域名|IP>..."; exit 1; }

for host in "$@"; do
  # 1) 能否解析(IP 直接跳过解析)
  if [[ "$host" =~ ^[0-9]{1,3}(\.[0-9]{1,3}){3}$ ]]; then
    ips="$host"
  else
    ips=$(getent hosts "$host" | awk '{print $1}' | sort -u | tr '\n' ' ')
    if [ -z "$ips" ]; then
      printf '%-32s ❌ 域名解析失败(DNS 或拼写问题,与防火墙无关)\n' "$host"
      continue
    fi
  fi

  # 2) 443 端口能否连通(走容器防火墙)
  code=$(curl -sS -o /dev/null -w '%{http_code}' --connect-timeout 5 "https://$host" 2>/dev/null || echo 000)
  if [ "$code" != "000" ]; then
    printf '%-32s ✅ 可访问 (HTTP %s)  IP: %s\n' "$host" "$code" "$ips"
  else
    # 再确认是不是被防火墙拦:看解析到的 IP 在不在放行集合
    inset="否"
    for ip in $ips; do
      sudo /usr/local/bin/fw-allow.sh --list 2>/dev/null | grep -qx "$ip" && inset="是"
    done
    if [ "$inset" = "否" ]; then
      printf '%-32s ⛔ 被防火墙拦截(不在白名单)  IP: %s\n' "$host" "$ips"
      printf '     → 放行: 在 host 上 echo "%s" >> firewall/allowlist.txt 然后 fw reload\n' "$host"
    else
      printf '%-32s ⚠️  在白名单但连不上(对方服务/端口问题,或 IP 已轮换) IP: %s\n' "$host" "$ips"
      printf '     → 若是 CDN,试 fw reload 重新解析\n'
    fi
  fi
done

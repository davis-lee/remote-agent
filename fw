#!/bin/bash
# 防火墙白名单动态管理(容器内任意用户可用,无需 rebuild/recompose)
#   fw allow <域名|IP|CIDR>...   即时放行并持久化到 allowlist.txt
#   fw reload                    从文件重建全部规则(等同重跑防火墙脚本)
#   fw list                      查看当前放行的 IP 集合
set -euo pipefail
ALLOWFILE=/etc/firewall/allowlist.txt

cmd="${1:-help}"; shift 2>/dev/null || true

case "$cmd" in
  allow)
    [ "$#" -eq 0 ] && { echo "用法: fw allow <域名|IP|CIDR>..."; exit 1; }
    # 若挂了外部文件目录,确保文件存在
    [ -d /etc/firewall ] && [ ! -f "$ALLOWFILE" ] && : > "$ALLOWFILE" 2>/dev/null || true
    for entry in "$@"; do
      if [[ "$entry" =~ ^[0-9]{1,3}(\.[0-9]{1,3}){3}(/[0-9]{1,2})?$ ]]; then
        sudo /usr/local/bin/fw-allow.sh "$entry"           # IP/CIDR:直接加
        echo "已放行 $entry"
      else
        ips=$(dig +short A "$entry" | grep -E '^[0-9.]+$' || true)   # 域名:先解析
        [ -z "$ips" ] && { echo "解析失败,跳过:$entry" >&2; continue; }
        sudo /usr/local/bin/fw-allow.sh $ips
        echo "已放行 $entry -> $ips"
      fi
      # 持久化到文件(去重);只读挂载(host-only)时写入失败则提示,仅临时放行
      if [ -f "$ALLOWFILE" ]; then
        if grep -qxF "$entry" "$ALLOWFILE" 2>/dev/null; then
          :
        elif echo "$entry" >> "$ALLOWFILE" 2>/dev/null; then
          :
        else
          echo "  (白名单为只读:本次仅临时放行;请在 host 编辑 allowlist.txt 后 fw reload)" >&2
        fi
      else
        echo "注意:未挂载 /etc/firewall,本次为临时放行,重启后失效" >&2
      fi
    done
    ;;
  reload)
    sudo /usr/local/bin/init-firewall.sh
    ;;
  list)
    sudo /usr/local/bin/fw-allow.sh --list
    ;;
  *)
    cat <<'EOF'
用法:
  fw allow <域名|IP|CIDR>...   即时放行并持久化(无需 rebuild)
  fw reload                    从 allowlist.txt 重建全部规则
  fw list                      查看当前放行的 IP 集合
EOF
    ;;
esac
